{
  "name": "@promptfire/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "predev": "pnpm --dir ../.. --filter @promptfire/api^... build",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/local.ts",
    "test": "vitest run",
    "test:semantic-evals": "vitest run src/semanticEval.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@promptfire/db": "workspace:*",
    "@promptfire/heuristics": "workspace:*",
    "@promptfire/shared": "workspace:*",
    "drizzle-orm": "^0.44.6",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
