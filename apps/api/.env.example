PORT=3001

# Legacy static key auth (optional during transition)
API_AUTH_BYPASS=true
API_STATIC_KEY=dev-key

# Rewrite provider
REWRITE_PROVIDER_MODE=mock
REWRITE_PROVIDER_MODEL=gpt-4o-mini
REWRITE_PROVIDER_API_KEY=
REWRITE_PROVIDER_TIMEOUT_MS=15000

# API / app
API_CORS_ALLOW_ORIGIN=*
APP_BASE_URL=http://localhost:5173

# Auth/session
AUTH_INCLUDE_DEBUG_TOKEN=true
AUTH_SESSION_COOKIE_NAME=pf_session
AUTH_SESSION_TTL_MS=1209600000
AUTH_MAGIC_LINK_TTL_MS=900000
AUTH_MAGIC_LINK_CALLBACK_URL=http://localhost:5173/app/auth/callback
AUTH_RP_ID=localhost

# Database
DATABASE_URL=postgres://promptfire:promptfire@localhost:5432/promptfire
